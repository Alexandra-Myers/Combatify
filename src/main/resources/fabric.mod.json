{
	"schemaVersion": 1,
	"id": "combatify",
	"version": "${version}",
	"name": "Combatify",
	"description": "A mod library and standalone mod that adds features from the combat test snapshots",
	"authors": [
		"Alexandra",
		"zOnlyKroks"
	],
  "contact": {
    "sources": "https://github.com/Alexandra-Myers/Combatify"
  },
  "license": "LGPL-2.1",
	"icon": "assets/combatify/icon.png",

	"environment": "*",
	"entrypoints": {
		"main": [
      "net.atlas.combatify.Combatify"
    ],
		"client": [
      "net.atlas.combatify.CombatifyClient"
    ],
    "sodium:config_api_user": [
      "net.atlas.combatify.compat.CombatifySodiumConfig"
    ]
	},
	"mixins": [
		"combatify.mixins.json"
	],
  "accessWidener": "combatify.classtweaker",
	"depends": {
    "fabric-api": ">=0.150.0+26.1.2",
    "atlas-core": ">=1.1.2",
    "defaulted": ">=1.2.2",
		"fabricloader": ">=0.17.2",
		"minecraft": ">=26.1.2 <26.2",
		"java": ">=25"
	},
  "suggests": {
    "modmenu": "*",
    "appleskin": "*",
    "cookeymod": "*"
  },
  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/client/renderer/entity/state/ArmedEntityRenderState": ["net/atlas/combatify/extensions/ArmedEntityRenderStateExtensions"],
      "net/minecraft/world/phys/BlockHitResult": ["net/atlas/combatify/extensions/BlockHitResultExtensions"],
      "net/minecraft/server/network/ServerConfigurationPacketListenerImpl": ["net/atlas/combatify/extensions/ClientInformationHolder"],
      "net/minecraft/world/entity/LivingEntity": ["net/atlas/combatify/extensions/LivingEntityExtensions"],
      "net/minecraft/world/entity/player/Player": ["net/atlas/combatify/extensions/PlayerExtensions"],
      "net/minecraft/server/level/ServerPlayer": ["net/atlas/combatify/extensions/ServerPlayerExtensions"],
      "net/minecraft/world/entity/Mob": ["net/atlas/combatify/extensions/MobExtensions"],
      "net/minecraft/network/protocol/game/ClientboundUpdateAttributesPacket": ["net/atlas/combatify/extensions/IUpdateAttributesPacket"],
      "net/minecraft/client/multiplayer/MultiPlayerGameMode": ["net/atlas/combatify/extensions/IPlayerGameMode"],
      "net/minecraft/world/damagesource/DamageSource": ["net/atlas/combatify/extensions/DamageSourceExtension"],
      "net/minecraft/world/food/FoodData": ["net/atlas/combatify/extensions/FoodDataExtensions"]
    }
  }
}
